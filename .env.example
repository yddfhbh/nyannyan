DISCORD_TOKEN=your_bot_token_here

# Optional: command registration target. If empty, the bot tries to infer it
# from SOURCE_CHANNEL_IDS. Set this if /업로드 does not appear quickly.
DISCORD_GUILD_ID=

# Only allow /업로드 in the problem upload channel.
SOURCE_CHANNEL_IDS=1509460473060261949

# /이동 scans every text channel inside this category.
PROBLEM_CATEGORY_ID=1509459977801044029

# By default, unit 1 goes to a channel named "1".
# Set UNIT_CHANNEL_PREFIX=unit- if your channels are named "unit-1", "unit-2", ...
UNIT_CHANNEL_PREFIX=

# Optional exact channel map. This wins over channel-name lookup.
# Example: UNIT_CHANNEL_MAP=1:123456789012345678,2:234567890123456789
UNIT_CHANNEL_MAP=
